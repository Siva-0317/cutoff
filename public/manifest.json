{
  "manifest_version": 3,
  "short_name": "Cutoff QuickAdd",
  "name": "Cutoff Subscription Tracker",
  "version": "1.0.0",
  "description": "Quickly add subscriptions to Cutoff from any website.",
  "action": {
    "default_popup": "index.html?ext=true",
    "default_title": "Add to Cutoff"
  },
  "permissions": [
    "activeTab"
  ],
  "icons": {
    "16": "favicon.ico",
    "64": "favicon.ico",
    "192": "logo192.png",
    "512": "logo512.png"
  }
}
